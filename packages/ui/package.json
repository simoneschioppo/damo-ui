{
  "name": "damo-ui",
  "version": "0.4.1",
  "type": "module",
  "description": "Damo UI — a React component library heavily inspired by Memphis Design",
  "license": "MIT",
  "author": "Simone Schioppo",
  "homepage": "https://github.com/simoneschioppo/damo-ui#readme",
  "bugs": {
    "url": "https://github.com/simoneschioppo/damo-ui/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "ui",
    "components",
    "component-library",
    "design-system",
    "memphis",
    "memphis-design",
    "tailwindcss",
    "tailwind-v4",
    "radix",
    "radix-ui",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/simoneschioppo/damo-ui.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/styles/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "import": "./dist/mocks/index.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/theme.css": "./dist/styles/theme.css",
    "./styles/globals.css": "./dist/styles/globals.css",
    "./tailwind.preset": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.js"
    }
  },
  "scripts": {
    "dev": "ladle serve",
    "build": "tsup && pnpm run build:types && pnpm run build:css && pnpm run build:preset",
    "build:types": "tsc -p tsconfig.dts.json",
    "build:css": "mkdir -p dist/styles && cp src/styles/*.css dist/styles/",
    "build:preset": "tsup tailwind.preset.ts --format esm --dts --out-dir dist --no-clean && node scripts/post-build.mjs dist/tailwind.preset.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4",
    "tailwindcss-animate": ">=1.0.7"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.5",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.5",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.5",
    "@radix-ui/react-toast": "^1.2.5",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "react-day-picker": "^10.0.0",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@ladle/react": "^4.1.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.16.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.1",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
