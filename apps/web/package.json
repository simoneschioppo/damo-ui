{
  "name": "@damo/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "REGISTRY_URL=http://localhost:3000/r node ../../packages/ui/scripts/build-registry/build.mjs",
    "dev": "next dev --port 3000",
    "build:registry": "node ../../packages/ui/scripts/build-registry/build.mjs",
    "build": "pnpm --filter damo-ui build && pnpm run build:registry && next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:generate": "tsx scripts/generate-icons.ts"
  },
  "dependencies": {
    "@shikijs/transformers": "^4.0.2",
    "damo-ui": "workspace:*",
    "next": "^15.0.0",
    "next-intl": "^4.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.16.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.47",
    "sharp": "^0.34.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
